#!/bin/bash

# 比赛/调图共用启动配置

# 导航读取的地图名，对应 pb2025_nav_bringup/map/reality/<WORLD>.yaml
WORLD="map"

# 1: 启动行为树自动跑点
# 0: 仅启动导航与串口，便于在 RViz 里手动点目标验证地图/点位
START_BEHAVIOR="0"

# 1: 打开 RViz
# 0: 不打开 RViz
USE_RVIZ="1"

# 一般实车保持 False
USE_ROBOT_STATE_PUB="False"

# 如需切换容器名可改这里
CONTAINER="ros_nav_stable_final"
