【启动命令汇总】
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # 导航（实车）
  source ~/ros_ws/install/setup.bash
  ros2 launch pb2025_nav_bringup rm_navigation_reality_launch.py \
    world:=three slam:=False use_robot_state_pub:=True use_rviz:=False

  # 行为树（另一个终端）
  source ~/ros_ws/install/setup.bash
  ros2 launch pb2025_sentry_behavior sentry_behavior.launch.py

  # 串口通信（另一个终端，如果没有被导航 launch 自动启动）
  source ~/ros_ws/install/setup.bash
  ros2 run my_serial_py serialpy_node
-->
<root BTCPP_format="4">

  <!-- 死亡等复活 -->
  <BehaviorTree ID="wait_for_respawn">
    <Sequence>
      <PublishSpinSpeed spin_speed="0.0" duration="0" topic_name="cmd_spin"/>
      <PublishTwist v_x="0.0" v_y="0.0" v_yaw="0.0" duration="0" topic_name="cmd_vel"/>
      <RetryUntilSuccessful num_attempts="-1">
        <Sequence>
          <Sleep msec="1000"/>
          <IsStatusOK ammo_min="0" heat_max="999999" hp_min="1" key_port="{@referee_robotStatus}"/>
        </Sequence>
      </RetryUntilSuccessful>
      <!-- 复活后重新开小陀螺 -->
      <PublishSpinSpeed spin_speed="5.0" duration="0" topic_name="cmd_spin"/>
    </Sequence>
  </BehaviorTree>

  <!-- 撤退到中心点 -->
  <BehaviorTree ID="retreat_to_center">
    <Sequence>
      <SendNav2Goal x="0.47" y="0.00" yaw="1.57" action_name="navigate_to_pose"/>
    </Sequence>
  </BehaviorTree>

  <!-- 主行为树 -->
  <BehaviorTree ID="rmul_2026_center_spin">
    <RetryUntilSuccessful num_attempts="-1">
      <Sequence>
        <!-- 等待比赛开始 -->
        <RetryUntilSuccessful num_attempts="-1">
          <Sequence>
            <Sleep msec="1000"/>
            <IsGameStatus name="IsGameStart"
                          max_remain_time="420"
                          min_remain_time="0"
                          expected_game_progress="4"
                          key_port="{@referee_gameStatus}"/>
          </Sequence>
        </RetryUntilSuccessful>

        <!-- 比赛开始, 先前往中心点 -->
        <SendNav2Goal x="0.47" y="0.00" yaw="1.57" action_name="navigate_to_pose"/>

        <!-- 到达中心点，开启小陀螺 -->
        <PublishSpinSpeed spin_speed="5.0" duration="0" topic_name="cmd_spin"/>

        <!-- 主循环 -->
        <KeepRunningUntilFailure>
          <ReactiveFallback>

            <!-- 优先级1: HP == 0 → 停车等复活 -->
            <ReactiveSequence>
              <Inverter>
                <IsStatusOK ammo_min="0" heat_max="999999" hp_min="1" key_port="{@referee_robotStatus}"/>
              </Inverter>
              <SubTree ID="wait_for_respawn"/>
            </ReactiveSequence>

            <!-- 优先级2: HP < 200 → 撤退到中心点 -->
            <ReactiveSequence>
              <Inverter>
                <IsStatusOK ammo_min="0" heat_max="999999" hp_min="200" key_port="{@referee_robotStatus}"/>
              </Inverter>
              <SubTree ID="retreat_to_center"/>
            </ReactiveSequence>

            <!-- 优先级3: HP >= 200 → 在中心点持续停留并保持小陀螺 -->
            <AlwaysSuccess/>

          </ReactiveFallback>
        </KeepRunningUntilFailure>

      </Sequence>
    </RetryUntilSuccessful>
  </BehaviorTree>

  <TreeNodesModel>
    <Condition ID="IsGameStatus">
      <input_port name="max_remain_time" default="420" type="int"/>
      <input_port name="min_remain_time" default="0" type="int"/>
      <input_port name="expected_game_progress" default="4" type="int"/>
      <input_port name="key_port" default="{@referee_gameStatus}" type="pb_rm_interfaces::msg::GameStatus_&lt;std::allocator&lt;void&gt; &gt;"/>
    </Condition>
    <Condition ID="IsStatusOK">
      <input_port name="ammo_min" default="0" type="int"/>
      <input_port name="heat_max" default="999999" type="int"/>
      <input_port name="hp_min" default="200" type="int"/>
      <input_port name="key_port" default="{@referee_robotStatus}" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;"/>
    </Condition>
    <Action ID="PubNav2Goal">
      <input_port name="x" default="0.0" type="double"/>
      <input_port name="y" default="0.0" type="double"/>
      <input_port name="yaw" default="0.0" type="double"/>
      <input_port name="topic_name" default="goal_pose" type="std::string"/>
    </Action>
    <Action ID="SendNav2Goal">
      <input_port name="x" default="0.0" type="double"/>
      <input_port name="y" default="0.0" type="double"/>
      <input_port name="yaw" default="0.0" type="double"/>
      <input_port name="action_name" default="navigate_to_pose" type="std::string"/>
    </Action>
    <Action ID="PublishSpinSpeed">
      <input_port name="spin_speed" default="5.0" type="double"/>
      <input_port name="duration" type="int"/>
      <input_port name="topic_name" default="cmd_spin" type="std::string"/>
    </Action>
    <Action ID="PublishTwist">
      <input_port name="v_x" default="0.0" type="double"/>
      <input_port name="v_y" default="0.0" type="double"/>
      <input_port name="v_yaw" default="0.0" type="double"/>
      <input_port name="duration" type="int"/>
      <input_port name="topic_name" default="cmd_vel" type="std::string"/>
    </Action>
  </TreeNodesModel>

</root>
